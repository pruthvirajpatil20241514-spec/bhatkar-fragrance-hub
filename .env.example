# Copy this file to .env and fill the values. Do NOT commit real credentials.

# ============================================================================
# PROJECT CONSOLIDATED ENVIRONMENT VARIABLES
# ============================================================================

# Database credentials (Railway MySQL Production)
DB_HOST=shinkansen.proxy.rlwy.net
DB_PORT=11735
DB_USER=root
DB_PASSWORD=your_database_password
DB_NAME=railway

# For local development with Docker Compose, use:
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=password
# DB_NAME=fragrance_hub

# Server Configuration
PORT=5000
API_BASE_URL=http://localhost:5000/api

# JWT Secret Key
JWT_SECRET_KEY=your_jwt_secret_key_generate_a_random_string

# Node Environment
NODE_ENV=development

# Frontend Configuration (Vite)
VITE_API_BASE_URL=http://localhost:5000/api
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id

# Railway Object Storage (S3-compatible)
S3_ENDPOINT=https://t3.storageapi.dev
S3_BUCKET=your_s3_bucket_name
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key
S3_REGION=us-east-1

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_from_razorpay_dashboard
RAZORPAY_WEBHOOK_URL=http://localhost:5000/api/payment/webhook

# Notes:
# - This .env file is used by both frontend and backend.
# - Frontend variables MUST start with VITE_ to be exposed to the UI.
# - Backend variables are loaded via process.env.
# - Keep real credentials out of version control.
