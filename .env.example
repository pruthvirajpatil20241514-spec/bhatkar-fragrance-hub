# Copy this file to .env and fill the values. Do NOT commit real credentials.

# Database credentials (Railway MySQL Production)
DB_HOST=shinkansen.proxy.rlwy.net
DB_PORT=11735
DB_USER=root
DB_PASS=your_database_password
DB_NAME=railway

# For local development with Docker Compose, use:
# DB_HOST=db
# DB_USER=bhatkar_user
# DB_PASS=super_secure_password_here
# DB_NAME=bhatkar_db

# Server Configuration
PORT=3000

# JWT Secret Key
JWT_SECRET_KEY=your_jwt_secret_key_generate_a_random_string

# Node Environment
NODE_ENV=development

# Railway Object Storage (S3-compatible)
S3_ENDPOINT=https://t3.storageapi.dev
S3_BUCKET=your_s3_bucket_name
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key

# Razorpay Payment Gateway
# Test Keys - for development and testing
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_from_razorpay_dashboard
RAZORPAY_WEBHOOK_URL=https://your-backend-domain.onrender.com/api/payment/webhook

# Production Keys - replace with actual production keys before deploying
# RAZORPAY_KEY_ID=your_razorpay_key_id
# RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# RAZORPAY_WEBHOOK_SECRET=your_production_webhook_secret

# Notes:
# - For production, do not store secrets in plain .env; use Docker secrets or a secret manager.
# - Webhook secrets are found in Razorpay Dashboard > Settings > Webhooks
# - Test payments: Use Razorpay test cards from https://razorpay.com/docs/payments/payments-landing-page/test-cards/
# - Keep credentials secure and never commit real credentials to version control
