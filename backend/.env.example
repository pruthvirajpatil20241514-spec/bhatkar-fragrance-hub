# ==============================================
# BACKEND ENVIRONMENT CONFIGURATION
# ==============================================
# Copy this file to .env and fill in your values
# NEVER commit .env file with real secrets!

# ==============================================
# DATABASE CONFIGURATION - Railway MySQL
# ==============================================
DB_HOST=shinkansen.proxy.rlwy.net
DB_USER=root
DB_PASS=your_railway_mysql_password
DB_NAME=railway
DB_PORT=11735

# For local docker-compose development:
# DB_HOST=localhost
# DB_USER=root
# DB_PASS=pass
# DB_NAME=fragrance_hub

# ==============================================
# SERVER CONFIGURATION
# ==============================================
PORT=3000
NODE_ENV=development
# Set to 'production' to enable SSL

# ==============================================
# JWT AUTHENTICATION
# ==============================================
JWT_SECRET_KEY=your_jwt_secret_key_here_min_32_chars_long

# ==============================================
# RAILWAY OBJECT STORAGE (S3-compatible)
# ==============================================
# For image uploads - set these in production deployment too
S3_ENDPOINT=https://t3.storageapi.dev
S3_BUCKET=your_bucket_name
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key

# ==============================================
# RAZORPAY PAYMENT GATEWAY
# ==============================================

# Razorpay API Credentials
# Get these from Razorpay Dashboard > Settings
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Razorpay Webhook Configuration
# Webhook Secret: Set in Razorpay Dashboard > Settings > Webhooks
# This secret is used to verify webhook signature (HMAC SHA256)
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Webhook URL
# This must match the URL registered in Razorpay Dashboard
# Format: https://your-backend-domain.com/api/payment/webhook
RAZORPAY_WEBHOOK_URL=https://bhatkar-fragrance-hub-backend.onrender.com/api/payment/webhook

# ==============================================
# PAYMENT CONFIGURATION
# ==============================================

# Enable/disable payment processing
PAYMENT_GATEWAY_ENABLED=true

# Payment processing timeout (milliseconds)
PAYMENT_TIMEOUT=30000

# ==============================================
# LOGGING CONFIGURATION
# ==============================================
LOG_LEVEL=info
# Options: error, warn, info, debug

# ==============================================
# CORS CONFIGURATION
# ==============================================
CORS_ORIGIN=https://bhatkar-fragrance-hub-1.onrender.com
# For development: http://localhost:5173

# ==============================================
# OPTIONAL: EMAIL NOTIFICATIONS
# ==============================================
# For payment confirmation/failure emails
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=noreply@yourdomain.com

# ==============================================
# OPTIONAL: ADMIN DASHBOARD
# ==============================================
# ADMIN_DASHBOARD_URL=https://admin.yourdomain.com

# ==============================================
# OPTIONAL: ANALYTICS
# ==============================================
# ANALYTICS_ENABLED=false
# ANALYTICS_API_KEY=your_analytics_api_key
